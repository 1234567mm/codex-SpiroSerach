{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/custom-htl-calculation.schema.json",
  "title": "CustomHtlCalculation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "calculation_id",
    "input_sha256",
    "output_sha256",
    "converged",
    "properties",
    "warnings"
  ],
  "properties": {
    "schema_version": { "const": "v17.custom_htl_calculation.v1" },
    "calculation_id": { "type": "string", "minLength": 1 },
    "input_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "output_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "converged": { "type": "boolean" },
    "properties": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "homo_ev": { "type": "number" },
        "lumo_ev": { "type": "number" },
        "band_gap_ev": { "type": "number" }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
