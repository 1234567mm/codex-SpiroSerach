{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/run-artifact.schema.json",
  "title": "RunArtifact",
  "$comment": "Metadata contract for one artifact entry in run-manifest.json. Payload schemas are referenced by schema_ref when available.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "input_hash",
    "generated_at",
    "producer_version",
    "path",
    "kind",
    "format",
    "schema_ref",
    "sha256",
    "bytes",
    "record_count",
    "join_keys",
    "depends_on"
  ],
  "properties": {
    "schema_version": { "const": "v6.run_artifact.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "input_hash": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer_version": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "kind": {
      "enum": [
        "acquisition_breakdown",
        "agent_trace",
        "canonical_evidence",
        "candidate_evidence_links",
        "candidate_identity_registry",
        "conflict_report",
        "data_quality_report",
        "device_evidence",
        "enrichment_results",
        "extraction_evaluation",
        "external_dataset_records",
        "ledger",
        "literature_claims",
        "literature_search_results",
        "model_evaluation",
        "model_updates",
        "obsidian_notes",
        "paper_cross_ref_report",
        "extraction_journal",
        "extraction_journal_status",
        "paper_vault_summary",
        "posterior",
        "production_beard_cole_snapshot",
        "provider_cache",
        "provider_cache_index",
        "provider_capabilities",
        "recommendations",
        "recompute_markers",
        "review_events",
        "review_queue",
        "review_summary",
        "scoring_view",
        "screening_input_view",
        "source_assets",
        "scientific_source_ledger",
        "training_snapshot",
        "v22_independent_snapshot_report",
        "v22_literature_benchmark_report",
        "v22_model_activation_report",
        "v22_quality_report",
        "v22_scientific_closure_report",
        "v22_zero_leakage_report",
        "v23_action_results",
        "v23_command_audit",
        "v23_recompute_job_status",
        "v24_admission_report",
        "v24_loop_state",
        "v24_recommendations",
        "v24_experiment_requests",
        "v24_handoff_export",
        "v24_observation_import",
        "v24_observation_projection",
        "v24_loop_controls_report",
        "v24_project_evolution",
        "v24_stop_continue_report",
        "v25_migration_policy",
        "v25_performance_budget_report",
        "v25_recovery_runbook",
        "v25_release_checklist",
        "v25_release_profile",
        "v25_security_audit_report",
        "v28_acquisition_strategy_comparison",
        "v28_incident_checklist",
        "v28_local_rehearsal_report",
        "v28_model_admission_decision",
        "v28_scale_readiness_report",
        "audit_graph_snapshot"
      ]
    },
    "format": { "enum": ["json", "jsonl"] },
    "schema_ref": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "bytes": { "type": "integer", "minimum": 0 },
    "record_count": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "join_keys": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
