{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/v25-release-checklist.schema.json",
  "title": "V25ReleaseChecklist",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "release_checklist_id", "reproducibility_bundle_id", "release_profile_id", "release_status", "reason_codes", "evidence", "claims", "signed_by"],
  "properties": {
    "schema_version": { "const": "v25.release_checklist.v1" },
    "release_checklist_id": { "type": "string", "minLength": 1 },
    "reproducibility_bundle_id": { "type": "string", "minLength": 1 },
    "release_profile_id": { "type": "string", "minLength": 1 },
    "release_status": { "enum": ["pass", "blocked"] },
    "reason_codes": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "object" },
    "claims": { "type": "object" },
    "signed_by": { "type": "string", "minLength": 1 }
  }
}
