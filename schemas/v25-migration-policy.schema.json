{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/v25-migration-policy.schema.json",
  "title": "V25MigrationPolicy",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "policy_id", "release_profile_id", "policy_status", "reason_codes", "supported_artifact_kinds", "checked_artifacts"],
  "properties": {
    "schema_version": { "const": "v25.migration_policy.v1" },
    "policy_id": { "type": "string", "minLength": 1 },
    "release_profile_id": { "type": "string", "minLength": 1 },
    "policy_status": { "enum": ["pass", "blocked"] },
    "reason_codes": { "type": "array", "items": { "type": "string" } },
    "supported_artifact_kinds": { "type": "array", "items": { "type": "string" } },
    "checked_artifacts": { "type": "array" }
  }
}
