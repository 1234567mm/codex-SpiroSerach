{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/molecule-entity.schema.json",
  "title": "MoleculeEntity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "molecule_id",
    "name",
    "canonical_smiles",
    "inchi",
    "inchi_key",
    "cas_number",
    "synonyms",
    "external_ids",
    "structure_confidence",
    "structure_status"
  ],
  "properties": {
    "molecule_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "canonical_smiles": { "type": ["string", "null"] },
    "inchi": { "type": ["string", "null"] },
    "inchi_key": { "type": ["string", "null"] },
    "cas_number": { "type": ["string", "null"] },
    "synonyms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "external_ids": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "structure_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "structure_status": {
      "enum": ["missing", "partial", "resolved", "invalid"]
    }
  },
  "$defs": {
    "use_instance": {
      "title": "UseInstance",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "material_entity_id",
        "use_instance_id",
        "profile",
        "role",
        "evidence_refs"
      ],
      "properties": {
        "material_entity_id": { "type": "string", "minLength": 1 },
        "use_instance_id": { "type": "string", "minLength": 1 },
        "profile": {
          "enum": [
            "htl_replacement_profile",
            "molecular_htl_profile",
            "sam_interface_profile",
            "barrier_profile"
          ]
        },
        "role": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
