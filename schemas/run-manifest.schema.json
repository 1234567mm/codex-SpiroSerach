{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/run-manifest.schema.json",
  "title": "RunManifest",
  "$comment": "Manifest discovery contract for run artifacts. Runtime-specific context may extend the top-level manifest, but artifact entries are governed by run-artifact.schema.json.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "input_hash",
    "generated_at",
    "producer_version",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": "v6.run_manifest.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "input_hash": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer_version": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "run-artifact.schema.json" }
    }
  }
}
