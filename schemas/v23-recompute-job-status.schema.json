{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/v23-recompute-job-status.schema.json",
  "title": "V23RecomputeJobStatus",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "generated_at", "job_id", "request_id", "action_type", "job_status", "result_status", "reason_code", "retry_state"],
  "properties": {
    "schema_version": { "const": "v23.recompute_job_status.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "job_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "action_type": { "const": "recompute_request" },
    "job_status": { "enum": ["queued", "timeout", "cancelled", "partial_failure"] },
    "result_status": { "enum": ["accepted", "timeout", "cancelled", "partial_failure"] },
    "reason_code": { "type": "string", "minLength": 1 },
    "retry_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "retryable", "last_status"],
      "properties": {
        "attempt": { "type": "integer", "minimum": 0 },
        "retryable": { "type": "boolean" },
        "last_status": { "enum": ["accepted", "timeout", "cancelled", "partial_failure"] }
      }
    }
  }
}
