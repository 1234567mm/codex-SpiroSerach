{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/extraction-evaluation.schema.json",
  "title": "ExtractionEvaluation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "extractor_version", "gold_snapshot_hash", "counts", "metrics"],
  "properties": {
    "schema_version": { "const": "v13.extraction_evaluation.v1" },
    "extractor_version": { "type": "string", "minLength": 1 },
    "gold_snapshot_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["true_positive", "false_positive", "false_negative"],
      "properties": {
        "true_positive": { "type": "integer", "minimum": 0 },
        "false_positive": { "type": "integer", "minimum": 0 },
        "false_negative": { "type": "integer", "minimum": 0 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["precision", "recall", "f1"],
      "properties": {
        "precision": { "type": "number", "minimum": 0, "maximum": 1 },
        "recall": { "type": "number", "minimum": 0, "maximum": 1 },
        "f1": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
