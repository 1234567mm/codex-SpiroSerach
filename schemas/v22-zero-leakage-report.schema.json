{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/v22-zero-leakage-report.schema.json",
  "title": "V22ZeroLeakageReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "snapshot_id", "closure_gate_status", "checks"],
  "properties": {
    "schema_version": { "const": "v22.zero_leakage_report.v1" },
    "snapshot_id": { "type": "string", "minLength": 1 },
    "closure_gate_status": { "enum": ["pass", "blocked"] },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "status", "overlaps"],
      "properties": {
        "dimension": { "enum": ["doi", "source_id", "material_id", "candidate_id", "group_id"] },
        "status": { "enum": ["pass", "blocked"] },
        "overlaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "splits", "record_ids"],
            "properties": {
              "value": { "type": "string", "minLength": 1 },
              "splits": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              },
              "record_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            }
          }
        }
      }
    }
  }
}
