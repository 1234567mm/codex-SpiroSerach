    "loop_state_id": { "type": "string" },
    "recommendation_set_id": { "type": "string" },
    "request_set_id": { "type": "string" },
    "control_status": { "enum": ["pass", "blocked"] },
    "request_generation_allowed": { "type": "boolean" },
    "reason_codes": { "type": "array" },
    "replay_hash": { "type": "string" },
    "checks": { "type": "array" }
