{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spirosearch.local/schemas/v25-security-audit-report.schema.json",
  "title": "V25SecurityAuditReport",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "security_audit_id", "release_profile_id", "audit_status", "reason_codes"],
  "properties": {
    "schema_version": { "const": "v25.security_audit_report.v1" },
    "security_audit_id": { "type": "string", "minLength": 1 },
    "release_profile_id": { "type": "string", "minLength": 1 },
    "audit_status": { "enum": ["pass", "blocked"] },
    "reason_codes": { "type": "array", "items": { "type": "string" } }
  }
}
