  "workflow": {
    "schema_version": "v33c.htl_workflow.v1",
    "lane": "htl_only",
    "steps": [
      {
        "index": 1,
        "label": "Configure sources and extractor"
      },
      {
        "index": 2,
        "label": "Sync NOMAD HTL records by configured HTL list"
      },
      {
        "index": 3,
        "label": "Resolve molecule identity through PubChem"
      },
      {
        "index": 4,
        "label": "Discover literature metadata through Crossref and optional OpenAlex"
      },
      {
        "index": 5,
        "label": "Import user paper and SI groups"
      },
      {
        "index": 6,
        "label": "Parse and index knowledge assets"
      },
      {
        "index": 7,
        "label": "Extract HTL-relevant claims"
      },
      {
        "index": 8,
        "label": "Normalize evidence"
      },
      {
        "index": 9,
        "label": "Audit conflicts and missing provenance"
      },
      {
        "index": 10,
        "label": "Build scoring view after EvidenceQualityPolicy"
      },
      {
        "index": 11,
        "label": "Render report with citation-backed claims"
      }
    ],
    "target_fields": [
      "htl_name",
      "synonyms",
      "device_architecture",
      "device_stack",
      "perovskite_composition",
      "pce_percent",
      "voc_v",
      "jsc_ma_cm2",
      "fill_factor",
      "stability_condition",
      "doi",
      "source_url",
      "license",
      "processing_conditions",
      "evidence_provenance",
      "review_blockers"
    ],
    "gates": [
      "EvidenceQualityPolicy",
      "review_blockers_resolved",
      "citation_provenance_present"
    ]
  },
